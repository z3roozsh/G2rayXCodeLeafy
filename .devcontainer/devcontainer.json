{
  "name": "G2ray-Codespace",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "postStartCommand": "bash ./scripts/post-start.sh",
  "postAttachCommand": "bash ./g2ray.sh",
  "portsAttributes": {
    "443": {
      "label": "g2ray-vless",
      "protocol": "http",
      "onAutoForward": "silent",
      "visibility": "public"
    },
    "8443": {
      "label": "g2ray-ws-fallback",
      "protocol": "http",
      "onAutoForward": "silent",
      "visibility": "public"
    }
  },
  "forwardPorts": [443, 8443],
  "hostRequirements": {
    "cpus": 2
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
